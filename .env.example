# VendorFlow — Environment Variables
# Copy this file to .env and fill in your Supabase credentials
# NEVER commit .env — it is listed in .gitignore

# Supabase project URL (found in Supabase dashboard > Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (safe to use in server-side requests with RLS)
SUPABASE_ANON_KEY=your-anon-key-here

# Optional: App name override
APP_NAME=VendorFlow
